
#include <stdio.h>

int main() {
    int a[10][10], row, col;
    int i, j, sum;

    printf("Enter number of rows: ");
    scanf("%d", &row);

    printf("Enter number of columns: ");
    scanf("%d", &col);

    // Input matrix elements
    printf("Enter matrix elements:\n");
    for(i = 0; i < row; i++) {
        for(j = 0; j < col; j++) {
            scanf("%d", &a[i][j]);
        }
    }

    // Find column-wise sum
    printf("\nColumn-wise Sum:\n");
    for(j = 0; j < col; j++) {
        sum = 0;
        for(i = 0; i < row; i++) {
            sum += a[i][j];
        }
        printf("Sum of Column %d = %d\n", j + 1, sum);
    }

    return 0;
}