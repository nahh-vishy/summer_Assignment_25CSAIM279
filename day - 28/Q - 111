
#include <stdio.h>

struct Ticket {
    int ticketNo;
    char name[50];
    int seatNo;
    float fare;
    int booked;
};

struct Ticket t;

// Function to book a ticket
void bookTicket() {
    if (t.booked == 1) {
        printf("\nTicket is already booked!\n");
        return;
    }

    printf("\nEnter Ticket Number: ");
    scanf("%d", &t.ticketNo);

    printf("Enter Passenger Name: ");
    scanf("%s", t.name);

    printf("Enter Seat Number: ");
    scanf("%d", &t.seatNo);

    printf("Enter Fare: ");
    scanf("%f", &t.fare);

    t.booked = 1;
    printf("Ticket booked successfully!\n");
}

// Function to view ticket
void viewTicket() {
    if (t.booked == 0) {
        printf("\nNo ticket booked.\n");
        return;
    }

    printf("\n===== Ticket Details =====\n");
    printf("Ticket Number : %d\n", t.ticketNo);
    printf("Passenger Name: %s\n", t.name);
    printf("Seat Number   : %d\n", t.seatNo);
    printf("Fare          : %.2f\n", t.fare);
}

// Function to cancel ticket
void cancelTicket() {
    if (t.booked == 0) {
        printf("\nNo ticket to cancel.\n");
    } else {
        t.booked = 0;
        printf("Ticket cancelled successfully!\n");
    }
}

int main() {
    int choice;
    t.booked = 0;

    do {
        printf("\n===== Ticket Booking System =====\n");
        printf("1. Book Ticket\n");
        printf("2. View Ticket\n");
        printf("3. Cancel Ticket\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                bookTicket();
                break;
            case 2:
                viewTicket();
                break;
            case 3:
                cancelTicket();
                break;
            case 4:
                printf("Exiting program...\n");
                break;
            default:
                printf("Invalid choice! Please try again.\n");
        }

    } while (choice != 4);

    return 0;
}